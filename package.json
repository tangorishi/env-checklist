{
  "name": "env-checklist",
  "version": "1.0.0",
  "description": "Ensure your environment variables are flight-ready before takeoff.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "env-checklist": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --clean --minify",
    "dev": "tsup src/index.ts --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "env",
    "dotenv",
    "validation",
    "checker",
    "preflight",
    "checklist",
    "cli"
  ],
  "author": "Rishi Joshi",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.37",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
